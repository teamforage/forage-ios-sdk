# Copy this file to `.env` in the same directory and fill in the values.
# `.env` is gitignored — never commit populated credentials.
# Fastlane auto-loads Sample/fastlane/.env when you run `bundle exec fastlane ...` from Sample/.

# --- App Store Connect API key (required for match) ---
# Obtain from: App Store Connect → Users and Access → Integrations → Keys
MATCH_KEY_ID=
MATCH_ISSUER_ID=

# Paste the FULL contents of the AuthKey_XXXX.p8 file, including the
# -----BEGIN PRIVATE KEY----- and -----END PRIVATE KEY----- lines.
# Wrap in double quotes so newlines are preserved, e.g.:
# MATCH_P8="-----BEGIN PRIVATE KEY-----
# MIG...
# -----END PRIVATE KEY-----"
MATCH_P8=

# --- Match repo encryption passphrase ---
# Used to decrypt the teamforage/certificates repo.
MATCH_PASSWORD=

# --- BrowserStack (only needed for upload step, not for `match`) ---
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
